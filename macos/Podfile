platform :osx, '10.15'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'ephemeral', 'Flutter-Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure \"flutter pub get\" is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Flutter-Generated.xcconfig, then run \"flutter pub get\""
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_macos_podfile_setup

target 'Runner' do
  use_frameworks!

  flutter_install_all_macos_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_macos_build_settings(target)
  end

  # tflite_flutter 0.12.x loads the dylib from Contents/resources/ at runtime
  # but the podspec does not vendor it. Add a build phase so it is copied on
  # every flutter run / build from the pub-cache.
  require 'xcodeproj'
  proj_path = File.expand_path('../Runner.xcodeproj', __FILE__)
  project = Xcodeproj::Project.open(proj_path)
  project.targets.each do |target|
    next unless target.name == 'Runner'
    next if target.build_phases.any? { |bp| bp.respond_to?(:name) && bp.name == 'Copy TFLite dylib' }

    phase = target.new_shell_script_build_phase('Copy TFLite dylib')
    phase.shell_path = '/bin/sh'
    phase.shell_script = <<~SCRIPT
      DYLIB=$(find "$HOME/.pub-cache" -path "*/tflite_flutter-*/macos/libtensorflowlite_c-mac.dylib" 2>/dev/null | sort -V | tail -1)
      if [ -z "$DYLIB" ]; then
        echo "warning: libtensorflowlite_c-mac.dylib not found in pub-cache - Focus Guard will be disabled"
        exit 0
      fi
      DEST="${BUILT_PRODUCTS_DIR}/${PRODUCT_NAME}.app/Contents/resources"
      mkdir -p "$DEST"
      cp -f "$DYLIB" "$DEST/libtensorflowlite_c-mac.dylib"
    SCRIPT
  end
  project.save
end
